{
  "name": "lotus-growth",
  "version": "0.1.0",
  "description": "Open-source growth agent starter kit for founders, indie hackers, and small teams.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "bin": {
    "lotus-growth": "./bin/lotus-growth.mjs"
  },
  "scripts": {
    "start": "node ./bin/lotus-growth.mjs",
    "demo": "node ./bin/lotus-growth.mjs demo",
