{
  "name": "lotus-growth",
  "version": "0.1.0",
  "description": "Open-source growth agent starter kit for founders, indie hackers, and small teams.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "homepage": "https://github.com/nicemango/lotus-growth#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicemango/lotus-growth.git"
  },
  "bugs": {
    "url": "https://github.com/nicemango/lotus-growth/issues"
  },
  "files": [
    "bin",
    "config",
    "docs",
    "src",
    "website",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "lotus-growth": "./bin/lotus-growth.mjs"
  },
  "scripts": {
    "start": "node ./bin/lotus-growth.mjs",
    "demo": "node ./bin/lotus-growth.mjs demo",
    "status": "node ./bin/lotus-growth.mjs status",
    "plan": "node ./bin/lotus-growth.mjs plan",
    "draft": "node ./bin/lotus-growth.mjs draft",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "growth",
    "agent",
    "marketing",
    "indie-hacker",
    "automation",
    "startup"
  ],
  "engines": {
    "node": ">=20"
  }
}
